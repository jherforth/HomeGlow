    "axios": "^1.15.2",
    "cron-parser": "^5.5.0",
    "hammerjs": "^2.0.8",
    "moment": "^2.30.1",
    "react": "^19.2.1",
    "react-big-calendar": "^1.19.4",
    "react-color": "2.19.3",
    "react-dom": "^19.2.1",
    "react-grid-layout": "^2.1.0",
    "react-rnd": "^10.5.2",
    "recharts": "^3.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
