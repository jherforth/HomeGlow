# Never copy host-built artifacts into the image.
# better-sqlite3 is a native module and MUST be built inside the container;
# copying a macOS/Windows-built node_modules causes "invalid ELF header".
node_modules
npm-debug.log

# Local data / secrets — keep out of the image build context.
# `widgets/` holds runtime-uploaded custom widgets; the directory is created at
# runtime by the Dockerfile (`mkdir -p /app/widgets`), so nothing here needs to
# be copied from the build context.
data
uploads
widgets/

# Misc
.env
**/.env
coverage
*.lcov
.git
.DS_Store
