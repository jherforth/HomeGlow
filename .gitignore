# Ignore all .env files
.env

# Optionally, ignore .env files in subdirectories too
**/.env

# You might also want to ignore node_modules and build outputs
node_modules/
dist/
build/
coverage/
**/coverage/
*.lcov

# Runtime uploads (user avatars, photos, uploaded sounds). Bundled default
# sounds live in server/assets/ and ARE tracked; seeded copies land here.
server/uploads/

# Local SQLite database (runtime data, initialized by migrations)
server/data/*.db
server/data/*.db-journal
server/data/*.db-wal
server/data/*.db-shm

# Generated encryption key (secret, do not commit)
server/data/.encryption-key

package-lock.json

.vscode/

# Local dev runtime data created by docker-compose-dev.yml (SQLite DB, uploads,
# auto-generated encryption key) — must never be committed.
homeglowdev/

# IDE / tooling
.idea/
.tool-versions
